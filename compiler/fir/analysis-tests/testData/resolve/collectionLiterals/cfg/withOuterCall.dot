digraph withOuterCall_kt {
    graph [nodesep=3]
    node [shape=box penwidth=2]
    edge [penwidth=2]

    subgraph cluster_0 {
        color=red
        0 [label="Enter file withOuterCall.kt" style="filled" fillcolor=red];
        1 [label="Exit file withOuterCall.kt" style="filled" fillcolor=red];
    }
    0 -> {1} [color=green];

    subgraph cluster_1 {
        color=red
        2 [label="Enter function foo" style="filled" fillcolor=red];
        subgraph cluster_2 {
            color=blue
            3 [label="Enter block"];
            4 [label="Exit block"];
        }
        5 [label="Exit function foo" style="filled" fillcolor=red];
    }
    2 -> {3};
    3 -> {4};
    4 -> {5};

    subgraph cluster_3 {
        color=red
        6 [label="Enter function test" style="filled" fillcolor=red];
        subgraph cluster_4 {
            color=blue
            7 [label="Enter block"];
            subgraph cluster_5 {
                color=blue
                8 [label="Function call arguments enter"];
                9 [label="Const: Int(1)"];
                10 [label="Const: Int(2)"];
                11 [label="Const: Int(3)"];
                12 [label="Function call arguments exit"];
            }
            13 [label="Function call enter: R|/foo|(...)"];
            14 [label="Function call exit: R|/foo|(...)" style="filled" fillcolor=yellow];
            15 [label="Exit block"];
        }
        16 [label="Exit function test" style="filled" fillcolor=red];
    }
    6 -> {7};
    7 -> {8};
    8 -> {9};
    9 -> {10};
    10 -> {11};
    11 -> {12};
    12 -> {13};
    13 -> {14};
    14 -> {15};
    15 -> {16};

}
